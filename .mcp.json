{
  "mcpServers": {
    "ml-intern": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}/mcp",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/server.py"
      ],
      "env": {
        "HF_TOKEN": "${HF_TOKEN}",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "ML_INTERN_PATH": "${CLAUDE_PLUGIN_ROOT}/tools/ml-intern"
      }
    }
  }
}
