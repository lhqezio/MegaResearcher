# Copy to .env and fill in. .env is gitignored.

# Required for HF tools (papers, datasets, docs, repo files).
# Get one at https://huggingface.co/settings/tokens — read scope is enough for v1.
HF_TOKEN=

# Optional. Only needed for the three GitHub tools (github_examples,
# github_list_repos, github_read_file). Without it, those tools return a clean
# error when called; the other six tools (HF + web_search) are unaffected.
# When set: public_repo scope is enough. Without it you also hit GitHub's
# 60 req/hour unauthenticated rate limit.
GITHUB_TOKEN=

# Optional: trace upload. If unset, the SessionEnd hook is a silent no-op.
# Set to "<your-hf-username>/ml-intern-sessions" (or any dataset repo you own).
ML_INTERN_TRACES_REPO=
ML_INTERN_TRACES_PRIVATE=true
